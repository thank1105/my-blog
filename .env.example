NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database
# Phase 0-9 uses SQLite locally; Phase 10 switches to PostgreSQL 17.
DATABASE_URL="file:./dev.db"

# NextAuth.js (Phase 1+)
# 48+ bytes of random data. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Rotate between environments; never reuse the dev secret in production.
NEXTAUTH_SECRET="replace-me-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"