# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (do not commit)
/.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma
/prisma/*.db
/prisma/*.db-journal
/prisma/migrations/dev.db*

# IDE
/.vscode/
/.idea/

# OS
Thumbs.db

# Stray dev.db (defensive — schema should create prisma/dev.db, but a root file may appear if a wrong CWD is used during an aborted Prisma run)
/dev.db
/dev.db-journal


# Dev server smoke test artifacts (created by pnpm dev smoke tests)
/dev-server.log
/dev-server.err


# One-off debugging scripts (Phase 2 Day 1 verification only); safe to delete.
# All ad-hoc probes / inspectors / wip fixes follow the verb- prefix pattern.
/scripts/probe-*.mjs
/scripts/inspect-*.mjs
/scripts/fix-*.mjs
/scripts/wipe-*.mjs
/scripts/download-*.mjs
/scripts/normalize-*.mjs


# Uploaded cover images (Phase 3 / Day 1). Phase 10 will swap local disk
# for cloud storage; the public/ prefix stays the same so call sites do not change.
/public/uploads/


# One-off scripts written during the Day 1 / Day 2 implementation passes
# that did not graduate into reusable utilities. Safe to delete. Each file's
# body still reads '// one-off ...; safe to delete'.
/scripts/add-*.mjs
/scripts/check-*.mjs
/scripts/find-*.mjs
/scripts/insert-*.mjs
/scripts/move-*.mjs
/scripts/patch-*.mjs
/scripts/rm-*.mjs
/scripts/tick-*.mjs
/scripts/trim-*.mjs

