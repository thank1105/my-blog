{
  "name": "my-blog",
  "version": "0.1.0",
  "private": true,
  "description": "Personal blog system (Phase 0 scaffolding).",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "node scripts/db-prepare.cjs && prisma db push --skip-generate",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "postinstall": "prisma generate",
    "prisma:migrate": "node scripts/db-prepare.cjs && prisma migrate dev",
    "db:seed": "prisma db seed",
    "predev": "node scripts/db-prepare.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "next": "15.5.20",
    "next-auth": "4.24.14",
    "react": "19.1.8",
    "react-dom": "19.1.8",
    "react-hook-form": "7.82.0",
    "tailwind-merge": "2.5.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "24.10.1",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.10",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.2",
    "eslint-config-next": "15.5.20",
    "happy-dom": "15.11.7",
    "postcss": "8.5.6",
    "prettier": "3.9.2",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.19",
    "tsx": "4.20.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
